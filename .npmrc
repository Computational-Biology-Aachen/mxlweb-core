engine-strict=true
# min-release-age is intentionally disabled here: this package is consumed as a
# github: git dep by other repos. npm translates min-release-age into --before
# and passes it to the child npm process that prepares git deps. If the git dep's
# own .npmrc also sets min-release-age, both flags collide and the install fails.
# The consumer's lock file already pins the SHA — that is the supply-chain guard.
# min-release-age = 3 # days
